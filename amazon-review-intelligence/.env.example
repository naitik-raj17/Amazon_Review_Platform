# Data
DATA_PATH=data/reviews.csv

# Models
MODEL_DIR=models
DEFAULT_MODEL_TYPE=transformer

# API
API_HOST=0.0.0.0
API_PORT=8000

# Training
TFIDF_MAX_FEATURES=10000
LR_MAX_ITER=1000
RF_N_ESTIMATORS=200
TRANSFORMER_MODEL_NAME=distilbert-base-uncased
TRANSFORMER_EPOCHS=2
TRANSFORMER_BATCH_SIZE=16
MAX_SEQ_LENGTH=128
MIN_TOPIC_SIZE=15

# Logging
LOG_LEVEL=INFO
